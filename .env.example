# Backend
PORT=4000
# NODE_ENV=production (or any value other than development/test) requires TLS_CERT_PATH and TLS_KEY_PATH; server will not start over HTTP.

# Backend TLS (production): paths to PEM files. Required when NODE_ENV is not development/test. TLS 1.3 minimum.
# TLS_CERT_PATH=
# TLS_KEY_PATH=

# Frontend (Vite injects at build time)
# Development: leave empty to use dev proxy to localhost:4000
# Production: set to your backend origin with https (e.g. https://api.example.com) so all API traffic uses TLS 1.3+
VITE_API_BASE_URL=

# Asset generation script only (not used at runtime)
GEMINI_API_KEY=
