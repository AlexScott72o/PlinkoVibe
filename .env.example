# =============================================================================
# RGS (Remote Gaming Server) — port 4000
# =============================================================================
PORT=4000

# NODE_ENV=production (or any value other than development/test) requires TLS or proxy.
# NODE_ENV=development

# TLS (production): paths to PEM files. Required when not behind a TLS proxy.
# TLS_CERT_PATH=
# TLS_KEY_PATH=

# Set to "true" when running behind a TLS-terminating reverse proxy (e.g. Render, nginx).
# BEHIND_TLS_PROXY=true

# CORS: comma-separated list of allowed frontend origins.
# CORS_ORIGINS=https://plinkovibe.scott.co.im

# Log level: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info

# PAM base URL — used by the RGS to call the PAM's internal wallet API.
# Development: PAM runs on port 4001 by default.
PAM_BASE_URL=http://localhost:4001

# Shared HMAC secret for RGS→PAM internal API authentication.
# Must be the same value in both RGS and PAM. Generate with: openssl rand -hex 32
PAM_HMAC_SECRET=change-me-use-openssl-rand-hex-32

# JWT secret — used by PAM to sign tokens, and by RGS to verify them.
# Must be the same value in both RGS and PAM. Generate with: openssl rand -hex 32
PAM_JWT_SECRET=change-me-use-openssl-rand-hex-32

# =============================================================================
# PAM (Player Account Management) — port 4001
# =============================================================================
# PORT=4001

# CORS_ORIGINS=https://plinkovibe.scott.co.im
# LOG_LEVEL=info
# BEHIND_TLS_PROXY=true

# PAM_JWT_SECRET=change-me-use-openssl-rand-hex-32
# PAM_HMAC_SECRET=change-me-use-openssl-rand-hex-32

# =============================================================================
# Frontend (Vite injects at build time)
# =============================================================================

# RGS API base URL.
# Development: leave empty — Vite proxies /api -> localhost:4000
# Production: set to your RGS origin (e.g. https://api.plinkovibe.scott.co.im)
VITE_API_BASE_URL=

# PAM base URL.
# Development: leave empty — Vite proxies /pam -> localhost:4001
# Production: set to your PAM origin (e.g. https://pam.plinkovibe.scott.co.im)
VITE_PAM_BASE_URL=

# =============================================================================
# Asset generation script (not used at runtime)
# =============================================================================
GEMINI_API_KEY=
