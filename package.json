{
  "name": "plinko-vibe",
  "private": true,
  "workspaces": ["frontend", "rgs", "pam", "shared"],
  "scripts": {
    "install:all": "npm install",
    "dev": "concurrently -n f,r,p -c cyan,magenta,yellow \"npm run dev:frontend\" \"npm run dev:rgs\" \"npm run dev:pam\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:rgs": "npm run dev --workspace=rgs",
    "dev:pam": "npm run dev --workspace=pam",
    "build": "npm run build --workspace=frontend",
    "build:rgs": "npm run build --workspace=rgs",
    "build:pam": "npm run build --workspace=pam",
    "deploy": "bash scripts/deploy.sh",
    "generate-assets": "node scripts/generate-assets.js"
  },
  "devDependencies": {
    "@google/generative-ai": "^0.21.0",
    "concurrently": "^8.2.2"
  }
}
